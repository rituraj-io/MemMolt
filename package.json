{
  "name": "memmolt",
  "version": "1.0.0",
  "description": "Structured, searchable, long-term memory for AI agents. Hybrid FTS5 + vector search over a local SQLite store, exposed via MCP.",
  "main": "index.js",
  "bin": {
    "memmolt": "bin/memmolt.js"
  },
  "files": [
    "index.js",
    "bin/",
    "database/",
    "functions/",
    ".claude-plugin/plugin.json",
    ".mcp.json",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "benchmark": "node benchmark/search-benchmark.js"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rituraj-io/MemMolt.git"
  },
  "homepage": "https://github.com/rituraj-io/MemMolt#readme",
  "bugs": {
    "url": "https://github.com/rituraj-io/MemMolt/issues"
  },
  "keywords": ["memory", "mcp", "model-context-protocol", "sqlite", "vector-search", "fts5", "rag", "agent-memory", "claude-code"],
  "author": "Rituraj Phukan",
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0",
    "sqlite-vec": "^0.1.9"
  }
}
